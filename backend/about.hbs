<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Farbstroem — Third-Party Notices</title>
    <style>
        body { font-family: system-ui, sans-serif; margin: 2rem auto; max-width: 50rem; line-height: 1.5; color: #1a1a1a; }
        h1 { border-bottom: 2px solid #ddd; padding-bottom: .3rem; }
        h2 { margin-top: 2.5rem; border-bottom: 1px solid #eee; padding-bottom: .2rem; }
        .intro { color: #444; }
        ul.overview { columns: 2; }
        .used-by { font-size: .9rem; }
        .used-by a { text-decoration: none; }
        pre { background: #f6f8fa; padding: 1rem; overflow-x: auto; white-space: pre-wrap; border-radius: 6px; font-size: .8rem; }
    </style>
</head>
<body>
    <h1>Third-Party Notices</h1>
    <p class="intro">
        Farbstroem is distributed under the GNU Affero General Public License
        v3.0. It incorporates the open-source components listed below; their
        own license terms and required attribution notices are reproduced here.
        This file is generated by <code>cargo-about</code> from the backend
        dependency tree — regenerate it with
        <code>cargo about generate about.hbs -o ../THIRD_PARTY_NOTICES.html</code>.
    </p>

    <h2>Overview</h2>
    <ul class="overview">
        {{#each overview}}
        <li><a href="#{{id}}">{{name}}</a> &mdash; {{count}} crate(s)</li>
        {{/each}}
    </ul>

    {{#each licenses}}
    <h2 id="{{id}}">{{name}}</h2>
    <p class="used-by">Used by:
        {{#each used_by}}
        <a href="{{#if crate.repository}}{{crate.repository}}{{else}}https://crates.io/crates/{{crate.name}}{{/if}}">{{crate.name}} {{crate.version}}</a>{{#unless @last}}, {{/unless}}
        {{/each}}
    </p>
    <pre>{{text}}</pre>
    {{/each}}
</body>
</html>
