# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=

# OME API token — must match OME_API_TOKEN in docker-compose .env
OME_API_TOKEN=

# OME Admission Webhook secret — must match OME_WEBHOOK_SECRET in docker-compose .env
OME_WEBHOOK_SECRET=

# Admin password — plaintext, hashed at startup
ADMIN_PASSWORD=

# LiveKit — key must match the key name in livekit/livekit.yaml
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://lk.your-domain.com
