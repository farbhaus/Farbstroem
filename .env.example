# === Domain ===
# Your domain for production, used by OME and frontend
DOMAIN=localhost

# === Image ===
# Tag of the single-container image zcolor/farbstroem that deploy hosts pull.
# CI publishes :latest and :sha-<short> on every push to main. Pin to a sha for
# reproducible/rollback-able deploys; defaults to :latest if unset.
# Ignored for local dev (docker-compose.override.yml builds from source).
# FARBSTROEM_TAG=latest

# === Component version pins (build-time) ===
# In the single-container image the component versions are baked in at BUILD
# time, not pulled at runtime. The defaults are pinned in the Dockerfile and are
# what CI bakes into the published image. The vars below only take effect for a
# LOCAL source build (docker-compose.override.yml passes them as build args):
#
#   docker compose up -d --build
#
# On a deploy host that PULLS zcolor/farbstroem they do nothing — the version is
# whatever CI baked; pin the whole image with FARBSTROEM_TAG above instead.
# CADDY_TAG / LIVEKIT_TAG / OME_TAG are Docker image tags; VALKEY_TAG's image
# suffix (e.g. -alpine) is stripped to the source-build version (8.1.7-alpine → 8.1.7).
CADDY_TAG=2.11.3-alpine
VALKEY_TAG=8.1.7-alpine
LIVEKIT_TAG=v1.12.0
OME_TAG=v0.20.5

# === Caddy ===
# Controls how the built-in Caddy listens:
#   "localhost"                → HTTP only, no TLS (local dev)
#   "stream.yourdomain.com"   → auto TLS via Let's Encrypt (standalone production)
#   ":80"                     → plain HTTP, for running behind an external reverse proxy
SITE_ADDRESS=localhost

# Browser-facing public host. Only needed when running behind an external TLS
# reverse proxy: there SITE_ADDRESS is a bare listen address like ":80" and is
# not a usable hostname, so set PUBLIC_HOST to the real domain the browser sees.
# Standalone deploys leave it unset — it defaults to SITE_ADDRESS. Drives
# PUBLIC_ORIGIN (https://) and LIVEKIT_URL (wss://.../livekit).
# PUBLIC_HOST=stream.yourdomain.com

# Port overrides (optional, for running behind another reverse proxy)
# HTTP_PORT=8880
# HTTPS_PORT=8444
# When behind an external TLS proxy, also bind the web ports to loopback so the
# plain-HTTP port isn't reachable from the internet (Docker bypasses ufw):
# WEB_BIND=127.0.0.1

# === Secrets (generate with: openssl rand -hex 32) ===
# JWT_SECRET, OME_WEBHOOK_SECRET, OME_API_TOKEN, and OME_SIGNED_POLICY_SECRET
# must be at least 32 characters.
JWT_SECRET=
OME_WEBHOOK_SECRET=
OME_API_TOKEN=
# Shared HMAC-SHA1 key for OME SignedPolicy SRT-playback tokens (Farbplay
# room-link flow, GitHub #165). Must match <SignedPolicy><SecretKey> in
# ome/origin_conf/Server.xml — both read OME_SIGNED_POLICY_SECRET.
OME_SIGNED_POLICY_SECRET=
# ADMIN_PASSWORD must be at least 12 characters.
ADMIN_PASSWORD=

# === SRT playback (Farbplay room-link flow, optional) ===
# Returned by GET /api/watch/<slug> as the SRT connection target.
# SRT_PUBLIC_HOST defaults to the host parsed from PUBLIC_ORIGIN.
# SRT_PUBLIC_PORT defaults to 9998 (the OME SRT publisher). SRT_LATENCY_MS to 500.
# SRT_PUBLIC_HOST=stream.yourdomain.com
# SRT_PUBLIC_PORT=9998
# SRT_LATENCY_MS=500

# === LiveKit ===
# LIVEKIT_API_KEY is an identifier (becomes the JWT `iss` claim) — required, no length limit.
# LIVEKIT_API_SECRET is used to sign LiveKit JWTs — must be at least 32 characters.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=
# NOTE: in the single-container image, LIVEKIT_URL and PUBLIC_ORIGIN are derived
# at startup (entrypoint.sh) from PUBLIC_HOST (which itself defaults to
# SITE_ADDRESS) — Caddy fronts everything over HTTPS and proxies LiveKit at
# /livekit, so the container sets LIVEKIT_URL=wss://<PUBLIC_HOST>/livekit and
# PUBLIC_ORIGIN=https://<PUBLIC_HOST> automatically, overriding the values below.
# Set SITE_ADDRESS (and PUBLIC_HOST only when behind a reverse proxy) and you're
# done. The two settings below only matter when running the backend bare
# (cargo run, no Caddy).

# Public URL sent to browser clients. Browsers reach LiveKit via Caddy, which
# proxies /livekit/* → localhost:7880, so it stays same-origin and Safari
# accepts the wss upgrade (plain ws:// from an https page is blocked as mixed
# content on Safari).
LIVEKIT_URL=wss://localhost/livekit

# Public origin the admin panel is served from. Used as the WebAuthn
# relying-party origin for passkey login (the RP ID is its host). Must be the
# EXACT browser origin: scheme + host[:port], NO path.
PUBLIC_ORIGIN=http://localhost:4001
