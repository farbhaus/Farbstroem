# === Domain ===
# Your domain for production, used by OME and frontend
DOMAIN=localhost

# === Caddy ===
# Controls how the built-in Caddy listens:
#   "localhost"                → HTTP only, no TLS (local dev)
#   "stream.yourdomain.com"   → auto TLS via Let's Encrypt (standalone production)
#   ":80"                     → plain HTTP, for running behind an external reverse proxy
SITE_ADDRESS=localhost

# Port overrides (optional, for running behind another reverse proxy)
# HTTP_PORT=8880
# HTTPS_PORT=8444

# === Secrets (generate with: openssl rand -hex 32) ===
# JWT_SECRET, OME_WEBHOOK_SECRET, and OME_API_TOKEN must be at least 32 characters.
JWT_SECRET=
OME_WEBHOOK_SECRET=
OME_API_TOKEN=
# ADMIN_PASSWORD must be at least 12 characters.
ADMIN_PASSWORD=

# === LiveKit ===
# LIVEKIT_API_KEY is an identifier (becomes the JWT `iss` claim) — required, no length limit.
# LIVEKIT_API_SECRET is used to sign LiveKit JWTs — must be at least 32 characters.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=
# Public URL sent to browser clients
# Local: ws://localhost:7880  |  Production: wss://lk.yourdomain.com
LIVEKIT_URL=ws://localhost:7880
