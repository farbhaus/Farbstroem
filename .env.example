# === Domain ===
# Your domain for production, used by OME and frontend
DOMAIN=localhost

# === Backend image ===
# Tag of zcolor/farbstroem-backend that deploy hosts pull. CI publishes
# :latest and :sha-<short> on every push to main. Pin to a sha for
# reproducible/rollback-able deploys; defaults to :latest if unset.
# Ignored for local dev (docker-compose.override.yml builds from source).
# BACKEND_TAG=latest

# === Upstream image pinning ===
# Compose defaults are floating (`:latest`, `:8-alpine`, …) for dev
# convenience, so a `docker compose pull` on a production host can swap a
# major version in unannounced. The values below are the recommended
# known-good pins — copying this file to `.env` activates them.
# `stream-valkey` runs Valkey (BSD-3 fork of Redis 7.2); Redis itself
# relicensed to SSPL/RSALv2 at 7.4.
CADDY_TAG=2.11.3-alpine
VALKEY_TAG=8.1.7-alpine
LIVEKIT_TAG=v1.12.0
OME_TAG=v0.20.5

# === Caddy ===
# Controls how the built-in Caddy listens:
#   "localhost"                → HTTP only, no TLS (local dev)
#   "stream.yourdomain.com"   → auto TLS via Let's Encrypt (standalone production)
#   ":80"                     → plain HTTP, for running behind an external reverse proxy
SITE_ADDRESS=localhost

# Port overrides (optional, for running behind another reverse proxy)
# HTTP_PORT=8880
# HTTPS_PORT=8444

# === Secrets (generate with: openssl rand -hex 32) ===
# JWT_SECRET, OME_WEBHOOK_SECRET, OME_API_TOKEN, and OME_SIGNED_POLICY_SECRET
# must be at least 32 characters.
JWT_SECRET=
OME_WEBHOOK_SECRET=
OME_API_TOKEN=
# Shared HMAC-SHA1 key for OME SignedPolicy SRT-playback tokens (Farbplay
# room-link flow, GitHub #165). Must match <SignedPolicy><SecretKey> in
# ome/origin_conf/Server.xml — both read OME_SIGNED_POLICY_SECRET.
OME_SIGNED_POLICY_SECRET=
# ADMIN_PASSWORD must be at least 12 characters.
ADMIN_PASSWORD=

# === SRT playback (Farbplay room-link flow, optional) ===
# Returned by GET /api/watch/<slug> as the SRT connection target.
# SRT_PUBLIC_HOST defaults to the host parsed from PUBLIC_ORIGIN.
# SRT_PUBLIC_PORT defaults to 9998 (the OME SRT publisher). SRT_LATENCY_MS to 500.
# SRT_PUBLIC_HOST=stream.yourdomain.com
# SRT_PUBLIC_PORT=9998
# SRT_LATENCY_MS=500

# === LiveKit ===
# LIVEKIT_API_KEY is an identifier (becomes the JWT `iss` claim) — required, no length limit.
# LIVEKIT_API_SECRET is used to sign LiveKit JWTs — must be at least 32 characters.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=
# Public URL sent to browser clients. Browsers see this via Caddy, which
# proxies /livekit/* → stream-livekit:7880, so it stays same-origin and
# Safari accepts the wss upgrade (plain ws:// from an https page is
# blocked as mixed content on Safari).
# Local: wss://localhost/livekit  |  Production: wss://${DOMAIN}/livekit
LIVEKIT_URL=wss://localhost/livekit

# Public origin the admin panel is served from. Used as the WebAuthn
# relying-party origin for passkey login (the RP ID is its host).
# Must be the EXACT browser origin: scheme + host[:port], NO path. env_file
# values are literal, so use a concrete URL, not ${DOMAIN}. deploy.sh sets the
# production value automatically; this default works for local dev.
# Local: http://localhost:4001  |  Production: https://stream.yourdomain.com
PUBLIC_ORIGIN=http://localhost:4001
