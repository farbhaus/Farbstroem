{$SITE_ADDRESS:localhost} {
	encode gzip zstd

	# Baseline security headers. HSTS is safe because Caddy terminates TLS
	# (auto-HTTPS); X-Frame-Options + frame-ancestors block clickjacking of
	# the admin panel; a conservative default CSP is the defence-in-depth
	# backstop for the innerHTML-heavy frontend. CDN-loaded runtime deps
	# (OvenPlayer, HLS.js, LiveKit) plus inline init scripts in www/*.html
	# need 'unsafe-inline' for now — tighten once those move to local hashes.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "interest-cohort=()"
		Content-Security-Policy "default-src 'self'; img-src 'self' data: blob:; media-src 'self' blob: https:; script-src 'self' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline'; connect-src 'self' ws: wss: https:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		-Server
	}

	# OME — LLHLS + WebRTC signaling (must be HTTP/1.1, unbuffered)
	handle /live/* {
		reverse_proxy stream-ome:3333 {
			transport http {
				versions 1.1
			}
			flush_interval -1
		}
	}

	# Trailing-slash redirects so relative <script src="./..."> paths resolve
	# the same regardless of how users type the URL.
	redir /admin /admin/ permanent

	# Everything else → backend (API + WebSocket + static files)
	reverse_proxy stream-backend:4001
}
