{$SITE_ADDRESS:localhost} {
	encode gzip zstd

	# Baseline security headers. HSTS is safe because Caddy terminates TLS
	# (auto-HTTPS); X-Frame-Options + frame-ancestors block clickjacking of
	# the admin panel; a conservative default CSP is the defence-in-depth
	# backstop for the innerHTML-heavy frontend. CDN-loaded runtime deps
	# (OvenPlayer, HLS.js, LiveKit) plus inline init scripts in www/*.html
	# need 'unsafe-inline' for now — tighten once those move to local hashes.
	#
	# Skipped on localhost: HSTS on localhost pins HTTPS forever against
	# Caddy's internal CA, which browsers trust inconsistently and breaks
	# OME/LiveKit WebRTC during local dev.
	@prod not host localhost
	header @prod {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "interest-cohort=()"
		Content-Security-Policy "default-src 'self'; img-src 'self' data: blob:; media-src 'self' blob: https:; font-src 'self' data:; script-src 'self' 'unsafe-inline' https:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' ws: wss: https:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		-Server
	}

	# LiveKit signaling — proxied as wss so the browser sees one origin.
	# Direct ws://localhost:7880 works on Chrome/Firefox but Safari rejects
	# it as mixed content from an https page. handle_path strips /livekit
	# so the upstream sees /rtc/v1 etc. unchanged.
	handle_path /livekit/* {
		reverse_proxy stream-livekit:7880 {
			header_up Host {upstream_hostport}
		}
	}

	# OME — LLHLS + WebRTC signaling (must be HTTP/1.1, unbuffered)
	handle /live/* {
		reverse_proxy stream-ome:3333 {
			transport http {
				versions 1.1
			}
			flush_interval -1
		}
	}

	# Trailing-slash redirects so relative <script src="./..."> paths resolve
	# the same regardless of how users type the URL.
	redir /admin /admin/ permanent

	# Everything else → backend (API + WebSocket + static files)
	reverse_proxy stream-backend:4001
}

# LiveKit SFU subdomain — the browser uses it for WebSocket signaling, so it
# needs its own hostname. This Caddy owns the routing; the host Caddy (if any)
# is just a TLS front that forwards Host: lk.<domain> here.
#   standalone:        LK_SITE_ADDRESS=lk.<domain>        (Caddy auto-TLS)
#   behind host Caddy: LK_SITE_ADDRESS=http://lk.<domain> (host Caddy does TLS)
#   local dev:         default lk.localhost — never hit
{$LK_SITE_ADDRESS:lk.localhost} {
	reverse_proxy stream-livekit:7880 {
		header_up Host {upstream_hostport}
	}
}
